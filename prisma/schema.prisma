generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

// Existing Enums
enum UserType {
  MINER
  PROJECT_OWNER
  BOTH
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum PostVisibility {
  PUBLIC
  FOLLOWERS_ONLY
  PRIVATE
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  AVATAR
}

enum NotificationType {
  FOLLOW
  LIKE_POST
  LIKE_COMMENT
  COMMENT_POST
  REPLY_COMMENT
  MENTION
  SYSTEM
  CAMPAIGN_APPROVED         // NEW
  CAMPAIGN_REJECTED         // NEW
  TASK_APPROVED            // NEW
  TASK_REJECTED            // NEW
  PAYMENT_RECEIVED         // NEW
  NEW_CAMPAIGN             // NEW
  CAMPAIGN_ENDING_SOON     // NEW
}

// NEW Campaign Platform Enums
enum TokenStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  ACTIVE
  INACTIVE
}

enum CampaignType {
  SPRINT
  KARMA
  CIRCLE
  COMPETITION
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum TaskType {
  // Action Category
  VISIT_LINK
  INVITES
  PARTNERSHIP
  
  // Social Category
  TWITTER_FOLLOW
  TWITTER_RETWEET
  TWITTER_LIKE
  TWITTER_POST
  DISCORD_JOIN
  TELEGRAM_JOIN
  TIKTOK
  
  // Answer Category
  UPLOAD
  POLL
  TEXT_ANSWER
  NUMBER_ANSWER
  URL_ANSWER
  
  // On-Chain Category
  TOKEN_HOLD
  ONCHAIN_ACTION
  
  // Custom Category
  QUIZ
  SURVEY
  CONTENT_CREATION
  CUSTOM
  REFERRAL
}

enum VerificationType {
  AUTO
  MANUAL
  HYBRID
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  UNDER_REVIEW
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum BadgeTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
  LEGEND
}

enum ParticipationRole {
  MINER
  REVIEWER
  EDITOR
  ADMIN
}

// ============================================
// USER & PROFILE
// ============================================

model User {
  id            String     @id @default(uuid()) @db.Uuid
  email         String     @unique
  passwordHash  String     @map("password_hash")
  username      String     @unique
  userType      UserType   @default(MINER) @map("user_type")
  emailVerified Boolean    @default(false) @map("email_verified")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  lastLogin     DateTime?  @map("last_login")
  status        UserStatus @default(ACTIVE)
  referredBy    String?    @map("referred_by") @db.Uuid
  referrer      User?      @relation("UserReferrals", fields: [referredBy], references: [id])
  referrals     User[]     @relation("UserReferrals")
  referralCodes ReferralCode[]

  // Existing relations
  profile           UserProfile?
  walletAddresses   WalletAddress[]
  socialConnections SocialConnection[]
  
  // Social features
  posts                Post[]
  comments             Comment[]
  postLikes            PostLike[]
  commentLikes         CommentLike[]
  followers            Follow[]       @relation("UserFollowers")
  following            Follow[]       @relation("UserFollowing")
  media                Media[]
  notifications        Notification[]
  notificationsActedOn Notification[] @relation("NotificationActor")

  // NEW: Campaign Platform Relations
  ownedTokens           Token[]                  @relation("TokenOwner")
  ownedCampaigns        Campaign[]               @relation("CampaignOwner")
  campaignParticipations CampaignParticipation[]
  submissions           Submission[]
  reviews               Review[]                 @relation("Reviewer")
  paymentsReceived      Payment[]                @relation("PaymentRecipient")
  paymentsSent          Payment[]                @relation("PaymentSender")
  badges                UserBadge[]

  // Add these new relations:
  conversationsAsParticipant1 Conversation[] @relation("ConversationParticipant1")
  conversationsAsParticipant2 Conversation[] @relation("ConversationParticipant2")
  messagesSent                Message[]      @relation("MessageSender")

  @@index([email])
  @@index([username])
  @@map("users")
}

model UserProfile {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @map("user_id") @db.Uuid
  displayName           String?  @map("display_name")
  bio                   String?
  avatarUrl             String?  @map("avatar_url")
  
  // Campaign Stats (already exists!)
  totalEarned           Decimal  @default(0) @map("total_earned") @db.Decimal(20, 8)
  tasksCompleted        Int      @default(0) @map("tasks_completed")
  campaignsParticipated Int      @default(0) @map("campaigns_participated")
  
  // NEW: Additional Miner Stats
  experiencePoints      Int      @default(0) @map("experience_points")
  level                 Int      @default(1)
  trustScore            Int      @default(500) @map("trust_score")
  approvalRate          Decimal  @default(0) @map("approval_rate") @db.Decimal(5, 2)
  twitterHandle         String?  @map("twitter_handle")
  telegramHandle        String?  @map("telegram_handle")
  
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model WalletAddress {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  blockchain String
  address    String
  isPrimary  Boolean  @default(false) @map("is_primary")
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, blockchain, address])
  @@map("wallet_addresses")
}

model SocialConnection {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  platform         String
  platformUserId   String   @map("platform_user_id")
  platformUsername String?  @map("platform_username")
  connectedAt      DateTime @default(now()) @map("connected_at")
  isActive         Boolean  @default(true) @map("is_active")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("social_connections")
}

// ============================================
// CAMPAIGN PLATFORM - TOKEN MANAGEMENT
// ============================================

model Token {
  id              String      @id @default(uuid()) @db.Uuid
  ownerId         String      @map("owner_id") @db.Uuid
  name            String
  symbol          String
  description     String
  contractAddress String?     @map("contract_address")
  blockchain      String
  logoUrl         String?     @map("logo_url")
  websiteUrl      String?     @map("website_url")
  twitterUrl      String?     @map("twitter_url")
  discordUrl      String?     @map("discord_url")
  telegramUrl     String?     @map("telegram_url")
  status          TokenStatus @default(PENDING_REVIEW)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  owner     User       @relation("TokenOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@index([ownerId])
  @@index([status])
  @@map("tokens")
}

// ============================================
// CAMPAIGN PLATFORM - CAMPAIGNS
// ============================================

model Campaign {
  id              String         @id @default(uuid()) @db.Uuid
  tokenId         String         @map("token_id") @db.Uuid
  ownerId         String         @map("owner_id") @db.Uuid
  name            String
  description     String
  imageUrl        String?        @map("image_url")
  type            CampaignType
  status          CampaignStatus @default(DRAFT)
  startDate       DateTime       @map("start_date")
  endDate         DateTime       @map("end_date")
  totalRewardPool Decimal        @map("total_reward_pool") @db.Decimal(20, 8)
  participantLimit Int?          @map("participant_limit")
  participantCount Int           @default(0) @map("participant_count")
  viewCount       Int            @default(0) @map("view_count")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  token          Token                   @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  owner          User                    @relation("CampaignOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  tasks          Task[]
  participations CampaignParticipation[]
  payments       Payment[]
  referralCodes  ReferralCode[]

  @@index([tokenId])
  @@index([ownerId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("campaigns")
}

model CampaignParticipation {
  id           String   @id @default(uuid()) @db.Uuid
  campaignId   String   @map("campaign_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  joinedAt     DateTime @default(now()) @map("joined_at")
  completedAt  DateTime? @map("completed_at")
  tasksCompleted Int    @default(0) @map("tasks_completed")
  totalTasks   Int      @default(0) @map("total_tasks")
  role         ParticipationRole @default(MINER)
  
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([userId])
  @@map("campaign_participations")
}

// ============================================
// CAMPAIGN PLATFORM - TASKS
// ============================================

model Task {
  id                 String           @id @default(uuid()) @db.Uuid
  campaignId         String           @map("campaign_id") @db.Uuid
  title              String
  description        String
  type               TaskType
  verificationType   VerificationType @map("verification_type")
  requirements       Json?
  reward             Decimal          @default(0) @db.Decimal(20, 8)
  experiencePoints   Int              @default(0) @map("experience_points")
  order              Int              @default(0)
  isRequired         Boolean          @default(true) @map("is_required")
  estimatedTime      Int?             @map("estimated_time")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  submissions   Submission[]
  referralCodes ReferralCode[]

  @@index([campaignId])
  @@map("tasks")
}

// ============================================
// CAMPAIGN PLATFORM - SUBMISSIONS
// ============================================

model Submission {
  id          String           @id @default(uuid()) @db.Uuid
  taskId      String           @map("task_id") @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  proofUrl    String?          @map("proof_url")
  proofText   String?          @map("proof_text")
  proofFiles  String[]         @map("proof_files")
  status      SubmissionStatus @default(PENDING)
  submittedAt DateTime         @default(now()) @map("submitted_at")
  reviewedAt  DateTime?        @map("reviewed_at")

  task   Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  review Review?

  @@index([taskId])
  @@index([userId])
  @@index([status])
  @@map("submissions")
}

model Review {
  id           String   @id @default(uuid()) @db.Uuid
  submissionId String   @unique @map("submission_id") @db.Uuid
  reviewerId   String   @map("reviewer_id") @db.Uuid
  rating       Int?
  feedback     String?
  approved     Boolean
  reviewedAt   DateTime @default(now()) @map("reviewed_at")

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer   User       @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([reviewerId])
  @@map("reviews")
}

// ============================================
// CAMPAIGN PLATFORM - PAYMENTS
// ============================================

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  campaignId    String        @map("campaign_id") @db.Uuid
  senderId      String        @map("sender_id") @db.Uuid
  recipientId   String        @map("recipient_id") @db.Uuid
  amount        Decimal       @db.Decimal(20, 8)
  tokenSymbol   String        @map("token_symbol")
  blockchain    String
  txHash        String?       @map("tx_hash")
  status        PaymentStatus @default(PENDING)
  createdAt     DateTime      @default(now()) @map("created_at")
  completedAt   DateTime?     @map("completed_at")
  failureReason String?       @map("failure_reason")

  campaign  Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  sender    User     @relation("PaymentSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User     @relation("PaymentRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([senderId])
  @@index([recipientId])
  @@index([status])
  @@map("payments")
}

// ============================================
// CAMPAIGN PLATFORM - GAMIFICATION
// ============================================

model Badge {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String
  icon        String
  tier        BadgeTier
  criteria    Json
  createdAt   DateTime  @default(now()) @map("created_at")

  userBadges UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  badgeId   String   @map("badge_id") @db.Uuid
  earnedAt  DateTime @default(now()) @map("earned_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

// ============================================
// SOCIAL FEATURES (EXISTING - KEEP)
// ============================================

model Post {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  content       String
  mediaUrls     String[]       @map("media_urls")
  visibility    PostVisibility @default(PUBLIC)
  likesCount    Int            @default(0) @map("likes_count")
  commentsCount Int            @default(0) @map("comments_count")
  isEdited      Boolean        @default(false) @map("is_edited")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments Comment[]
  likes    PostLike[]
  media    Media[]

  @@index([userId])
  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id              String   @id @default(uuid()) @db.Uuid
  postId          String   @map("post_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  content         String
  parentCommentId String?  @map("parent_comment_id") @db.Uuid
  likesCount      Int      @default(0) @map("likes_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentComment Comment?      @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies       Comment[]     @relation("CommentReplies")
  likes         CommentLike[]

  @@index([postId])
  @@index([userId])
  @@index([parentCommentId])
  @@map("comments")
}

model PostLike {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@map("post_likes")
}

model CommentLike {
  id        String   @id @default(uuid()) @db.Uuid
  commentId String   @map("comment_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
  @@map("comment_likes")
}

model Follow {
  id          String   @id @default(uuid()) @db.Uuid
  followerId  String   @map("follower_id") @db.Uuid
  followingId String   @map("following_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  follower  User @relation("UserFollowers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model Media {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  postId    String?   @map("post_id") @db.Uuid
  type      MediaType
  url       String
  thumbnail String?
  filename  String
  filesize  Int
  mimeType  String    @map("mime_type")
  width     Int?
  height    Int?
  createdAt DateTime  @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post? @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
  @@map("media")
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  actorId   String?          @map("actor_id") @db.Uuid
  postId    String?          @map("post_id") @db.Uuid
  commentId String?          @map("comment_id") @db.Uuid
  message   String
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Conversation {
  id          String    @id @default(uuid()) @db.Uuid
  participant1Id String  @map("participant1_id") @db.Uuid
  participant2Id String  @map("participant2_id") @db.Uuid
  lastMessageAt DateTime @default(now()) @map("last_message_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  participant1 User      @relation("ConversationParticipant1", fields: [participant1Id], references: [id], onDelete: Cascade)
  participant2 User      @relation("ConversationParticipant2", fields: [participant2Id], references: [id], onDelete: Cascade)
  messages     Message[]

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  senderId       String       @map("sender_id") @db.Uuid
  content        String
  isRead         Boolean      @default(false) @map("is_read")
  createdAt      DateTime     @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model ReferralCode {
  id            String   @id @default(uuid()) @db.Uuid
  code          String   @unique
  userId        String   @map("user_id") @db.Uuid
  campaignId    String   @map("campaign_id") @db.Uuid
  taskId        String?  @map("task_id") @db.Uuid
  timesUsed     Int      @default(0) @map("times_used")
  maxUses       Int?     @map("max_uses")
  expiresAt     DateTime? @map("expires_at")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  task     Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([campaignId])
  @@index([code])
  @@map("referral_codes")
}